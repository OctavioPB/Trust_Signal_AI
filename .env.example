# ─────────────────────────────────────────────────────────────────────────────
# TrustSignal AI — Environment Variables
# Copy to .env and fill in values before starting the stack.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9095
KAFKA_TOPIC_AUDIO=interview-audio-stream
KAFKA_TOPIC_TEXT=interview-text-stream

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9200
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Delta Lake ────────────────────────────────────────────────────────────────
DELTA_LAKE_PATH=/delta

# ── Whisper STT ───────────────────────────────────────────────────────────────
# Options: tiny | base | small | medium | large
WHISPER_MODEL_SIZE=base

# ── OpenAI (optional — cloud Whisper fallback) ────────────────────────────────
# Leave empty to force local Whisper only
OPENAI_API_KEY=

# ── ML ────────────────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=data/vector_store
# Float 0–1: signals above this threshold trigger a suspicious flag
SUSPICION_THRESHOLD=0.65
# Target false-positive rate (used during calibration)
FALSE_POSITIVE_TARGET=0.02

# ── FastAPI ───────────────────────────────────────────────────────────────────
# Generate a strong random key for production: openssl rand -hex 32
FASTAPI_SECRET_KEY=dev-secret-replace-in-production
# Comma-separated CORS origins; add production URL in prod
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_HOME=/opt/airflow

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack Incoming Webhook for nightly DAG summary (leave empty to disable)
SLACK_WEBHOOK_URL=

# ── Whisper STT — performance tuning ─────────────────────────────────────────
# Max concurrent Whisper calls per consumer process.
# 1 = sequential (CPU < 60 % on 4-core host); 2 = default; 4+ for GPU hosts.
MAX_CONCURRENT_STT=2

# ── Error tracking ────────────────────────────────────────────────────────────
# Sentry DSN for FastAPI error reporting (leave empty to disable)
SENTRY_DSN=
